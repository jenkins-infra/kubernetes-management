controller:
  service:
    annotations:
      service.beta.kubernetes.io/azure-load-balancer-internal: "true"
      # TODO: track with updatecli from https://reports.jenkins.io/jenkins-infra-data-reports/azure.json
      service.beta.kubernetes.io/azure-load-balancer-internal-subnet: "{{ .StateValues.clusterName }}-commons"
      # TODO: track with updatecli from https://reports.jenkins.io/jenkins-infra-data-reports/azure.json
      service.beta.kubernetes.io/azure-load-balancer-ipv4: "{{ .StateValues.clusterLoadBalancerIp }}"
